{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Backend Node Debug",
      "skipFiles": [
        "<node_internals>/**"
      ],
      // ✨ Importante: Sostituisci con il percorso del tuo file di ingresso del backend
      "program": "${workspaceFolder}/app.js", 
      "console": "integratedTerminal",
      "runtimeArgs": ["--inspect"]
      // Se non funziona, potresti dover aggiungere: "runtimeArgs": ["--inspect"]
    }
  ]
}